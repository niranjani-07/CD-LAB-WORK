#include<stdio.h>
#include<string.h>

int main(){
    char infix[20];
    int i;

    printf("Enter infix expression: ");
    scanf("%s",infix);

    printf("\nPrefix: ");
    for(i=strlen(infix)-1;i>=0;i--)
        printf("%c",infix[i]);

    printf("\nPostfix: ");
    for(i=0;i<strlen(infix);i++)
        printf("%c",infix[i]);

    printf("\n");
}
