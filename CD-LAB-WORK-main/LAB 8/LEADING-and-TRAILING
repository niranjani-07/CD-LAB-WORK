#include<stdio.h>
#include<string.h>

int main(){
    char prod[10][10];
    int n,i;

    printf("Enter number of productions: ");
    scanf("%d",&n);

    printf("Enter productions:\n");
    for(i=0;i<n;i++)
        scanf("%s",prod[i]);

    printf("\nLEADING\n");
    for(i=0;i<n;i++){
        if(!(prod[i][2]>='A' && prod[i][2]<='Z'))
            printf("%c : %c\n",prod[i][0],prod[i][2]);
    }

    printf("\nTRAILING\n");
    for(i=0;i<n;i++){
        int len=strlen(prod[i]);
        if(!(prod[i][len-1]>='A' && prod[i][len-1]<='Z'))
            printf("%c : %c\n",prod[i][0],prod[i][len-1]);
    }
}
