#include<stdio.h>
#include<string.h>

int main(){
    char prod[10][10];
    int n,i;

    printf("Enter number of productions: ");
    scanf("%d",&n);

    printf("Enter productions:\n");
    for(i=0;i<n;i++)
        scanf("%s",prod[i]);

    printf("\nLR(0) Items\n");

    for(i=0;i<n;i++){
        int len=strlen(prod[i]);

        for(int j=0;j<=len;j++){
            for(int k=0;k<len;k++){
                if(k==j)
                    printf(".");
                printf("%c",prod[i][k]);
            }
            if(j==len)
                printf(".");
            printf("\n");
        }
        printf("\n");
    }
}
